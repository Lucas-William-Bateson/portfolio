# Portfolio (l3s.me) — Astro site

runner "default" {
  image = "node:20-slim"
}

on push("main"), pr("main") {
  stage install on runner.default {
    run "npm ci"
    timeout 5m
  }

  stage build on runner.default {
    needs install
    run "npm run build"
    artifacts "dist/"
    timeout 10m
  }

  stage deploy on runner.default {
    needs build
    condition on_push
    run "scripts/deploy.sh"
    deploy {
      name = "portfolio"
      domain = "l3s.me"
      port = 3000
      compose_file = "docker/docker-compose.yml"
    }
  }
}
