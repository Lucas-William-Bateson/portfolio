# Portfolio (l3s.me) — Astro site

runner "default" {
  image = "node:20-slim"
}

secrets from store("portfolio/prod") {
  CONTAINER_NAME
  IMAGE_FULL
  CPU_LIMIT
  MEMORY_LIMIT
  HOST_PORT
  APP_PORT
  APP_NAME
  ENVIRONMENT
  MAINTAINER_EMAIL
  NETWORK_NAME
}

on push("main"), pr("main") {
  stage install on runner.default {
    run "npm ci"
    timeout 5m
  }

  stage build on runner.default {
    needs install
    run "npm run build"
    artifacts "dist/"
    timeout 10m
  }

  stage release on runner.default {
    needs build
    condition on_push
    deploy {
      name = "portfolio"
      domain = "l3s.me"
      port = 3000
      compose_file = "docker/docker-compose.yml"
    }
  }
}
