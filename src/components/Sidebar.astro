---
type Link = { label: string; url: string };
const {
  name = 'Your Name',
  tagline = '',
  links = [] as Link[],
} = Astro.props as {
  name?: string;
  tagline?: string;
  links?: Link[];
};

function icon(name: string) {
  switch (name.toLowerCase()) {
    case 'github':
      return `<svg viewBox='0 0 24 24' width='14' height='14' fill='currentColor' aria-hidden='true'><path d='M12 .5A11.5 11.5 0 0 0 .5 12.3c0 5.24 3.42 9.68 8.17 11.25.6.11.83-.26.83-.58 0-.28-.01-1.03-.02-2.02-3.33.73-4.03-1.63-4.03-1.63-.54-1.37-1.33-1.73-1.33-1.73-1.09-.76.08-.74.08-.74 1.2.09 1.83 1.25 1.83 1.25 1.07 1.86 2.8 1.32 3.49 1.01.11-.8.42-1.32.76-1.63-2.66-.31-5.46-1.37-5.46-6.1 0-1.35.47-2.45 1.24-3.31-.12-.3-.54-1.57.12-3.27 0 0 1.01-.33 3.3 1.26a11.4 11.4 0 0 1 6 0c2.28-1.59 3.29-1.26 3.29-1.26.66 1.7.24 2.97.12 3.27.77.86 1.23 1.96 1.23 3.31 0 4.74-2.81 5.79-5.49 6.1.43.38.82 1.12.82 2.27 0 1.64-.02 2.96-.02 3.36 0 .32.22.69.83.58A11.52 11.52 0 0 0 23.5 12.3 11.5 11.5 0 0 0 12 .5Z'/></svg>`;
    case 'linkedin':
      return `<svg viewBox='0 0 24 24' width='14' height='14' fill='currentColor' aria-hidden='true'><path d='M4.98 3.5C4.98 4.88 3.88 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM0 8.98h5V24H0V8.98Zm7.55 0h4.79v2.04h.07c.67-1.27 2.31-2.6 4.76-2.6 5.09 0 6.03 3.35 6.03 7.71V24h-4.99v-6.66c0-1.59-.03-3.64-2.22-3.64-2.22 0-2.56 1.73-2.56 3.52V24H7.55V8.98Z'/></svg>`;
    case 'email':
      return `<svg viewBox='0 0 24 24' width='14' height='14' fill='currentColor' aria-hidden='true'><path d='M20 4H4a2 2 0 0 0-2 2v.2l10 6 10-6V6a2 2 0 0 0-2-2Zm0 4.4-8 4.8L4 8.4V18a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8.4Z'/></svg>`;
    default:
      return '';
  }
}
---
<aside class="md:sticky md:top-12 md:self-start" aria-label="Technical sidebar">
  <div class="space-y-6">
    <!-- Identity (minimal) -->
    <div>
      <div class="text-sm font-semibold text-text tracking-tight">{name}</div>
      {links.length ? (
        <div class="mt-2 flex items-center gap-2">
          {links.map(l => {
            const key = l.label.toLowerCase();
            const iconSvg = icon(key.includes('git') ? 'github' : key.includes('linked') ? 'linkedin' : key.includes('mail') ? 'email' : '');
            return iconSvg ? (
              <a href={l.url} class="text-muted/50 hover:text-primary transition-colors" target={l.url.startsWith('http') ? '_blank' : undefined} rel="noreferrer noopener" aria-label={l.label} set:html={iconSvg}></a>
            ) : null;
          })}
        </div>
      ) : null}
    </div>

    <div class="h-sep"></div>

    <!-- Focus Areas -->
    <div>
      <div class="text-[10px] font-semibold text-muted tracking-widest uppercase mb-2">Focus</div>
      <div class="space-y-0.5 text-xs text-text/80">
        <div>Simulation</div>
        <div>Estimation</div>
        <div>Control</div>
      </div>
    </div>

    <!-- Stack -->
    <div>
      <div class="text-[10px] font-semibold text-muted tracking-widest uppercase mb-2">Stack</div>
      <div class="space-y-0.5 text-xs text-text/80">
        <div>Rust</div>
        <div>Python</div>
        <div>Linux</div>
      </div>
    </div>

    <!-- Context -->
    <div>
      <div class="text-[10px] font-semibold text-muted tracking-widest uppercase mb-2">Context</div>
      <div class="text-xs text-text/80">
        Production systems<br />(NAV IT)
      </div>
    </div>
  </div>
</aside>
