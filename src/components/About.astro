---
const { about = [] as string[] } = Astro.props as { about?: string[] };
---
<section id="overview" class="py-10">
  <div class="container-narrow">
    <h2 class="section-title">Overview</h2>
    <div class="space-y-3 text-muted text-sm leading-relaxed">
      {about.map(p => (<p>{p}</p>))}
    </div>
  </div>
</section>
