---
type SkillGroup = { icon: string; title: string; items: string[] };
const { skills = [] as SkillGroup[] } = Astro.props as { skills?: SkillGroup[] };
---
<div class="grid gap-4 md:grid-cols-2">
  {skills.map((s) => (
    <div class="border border-border p-4">
      <div class="text-xs font-semibold text-text tracking-wide uppercase mb-2">{s.title}</div>
      <div class="text-sm text-muted/80">{s.items.join(' · ')}</div>
    </div>
  ))}
</div>
