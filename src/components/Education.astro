---
type Edu = { school: string; program?: string; years?: string; certificates?: string[] };
const { items = [] as Edu[] } = Astro.props as { items?: Edu[] };
---
{items && items.length ? (
  <div class="space-y-3">
    {items.map((e) => (
      <div>
        <div class="text-sm text-text">{e.school}</div>
        {e.program || e.years ? (
          <div class="text-sm text-muted/60">{[e.program, e.years].filter(Boolean).join(' · ')}</div>
        ) : null}
      </div>
    ))}
  </div>
) : null}
