---
interface Link { href: string; label: string }
const { name = 'Lucas Bateson', links = [
  { href: '#overview', label: 'Overview' },
  { href: '#work', label: 'Work' },
  { href: '#systems', label: 'Systems' },
  { href: '#contact', label: 'Contact' },
] as Link[] } = Astro.props as { name?: string; links?: Link[] };
---
<nav class="sticky top-0 z-10 bg-bg border-b border-border">
  <div class="container-narrow h-12 flex items-center justify-between">
    <a href="#top" class="font-medium text-text">{name}</a>
    <div class="hidden sm:flex gap-6 text-sm text-muted">
      {links.map(l => (<a class="hover:text-text transition-colors" href={l.href}>{l.label}</a>))}
    </div>
    <button class="sm:hidden px-2 py-1 text-sm text-muted" onclick="document.querySelector('ninja-keys')?.open()">Menu</button>
  </div>
</nav>
