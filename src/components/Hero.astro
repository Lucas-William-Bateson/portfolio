---
const { name = 'Lucas Bateson', tagline = '' } = Astro.props as { name?: string; tagline?: string };
---
<section id="top" class="py-16">
  <div class="container-narrow">
    <h1 class="text-2xl font-semibold text-text">{name}</h1>
    {tagline ? <p class="text-muted mt-1">{tagline}</p> : null}
  </div>
</section>
