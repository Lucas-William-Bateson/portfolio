---
type Project = {
  name: string;
  description: string;
  tags?: string[];
  url?: string;
  features?: string[];
  image?: string;
  highlight?: string;
};
const { projects = [] as Project[] } = Astro.props as { projects?: Project[] };
const featured = projects[0];
const secondary = projects.slice(1);
---
<div class="space-y-10">
  <!-- Primary System (Deadreckon) - Framed, not carded -->
  {featured && (
    <div class="border-l-2 border-text pl-5 py-1">
      <div class="flex items-baseline justify-between gap-4">
        <h3 class="text-base font-semibold text-text tracking-tight">{featured.name}</h3>
        {featured.url ? <a class="text-[10px] text-muted hover:text-primary transition-colors" href={featured.url} target="_blank" rel="noreferrer noopener">Source →</a> : null}
      </div>
      <p class="mt-2 text-sm text-muted leading-relaxed">{featured.description}</p>
      {featured.features && featured.features.length ? (
        <ul class="mt-3 space-y-1 text-sm text-muted/90">
          {featured.features.map(f => (<li class="flex items-start gap-2"><span class="text-text/30">—</span>{f}</li>))}
        </ul>
      ) : null}
    </div>
  )}

  <!-- Secondary Systems - Minimal list -->
  {secondary.length > 0 && (
    <div class="border-t border-border pt-6">
      <div class="space-y-4">
        {secondary.map((p) => (
          <div class="flex items-baseline justify-between gap-4">
            <div>
              <span class="text-sm text-text/70">{p.name}</span>
              <span class="text-sm text-muted/60 ml-2">— {p.description}</span>
            </div>
            {p.url ? <a class="text-[10px] text-muted/50 hover:text-primary transition-colors" href={p.url} target="_blank" rel="noreferrer noopener">Source</a> : null}
          </div>
        ))}
      </div>
    </div>
  )}
</div>
