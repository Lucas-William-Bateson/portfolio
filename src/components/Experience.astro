---
type Role = {
  role: string;
  company: string;
  summary: string;
  tags?: string[];
  time?: string;
  responsibilities?: string[];
  companyUrl?: string;
};
const { roles = [] as Role[] } = Astro.props as { roles?: Role[] };
---
<div class="space-y-6">
  {roles.map((r) => (
    <div>
      <div class="flex items-baseline justify-between gap-4">
        <div class="text-sm text-text">{r.role}</div>
        {r.time ? (<div class="text-[10px] text-muted/60 font-mono">{r.time}</div>) : null}
      </div>
      <div class="text-sm text-muted/70">
        {r.companyUrl ? (
          <a class="hover:text-primary transition-colors" href={r.companyUrl} target="_blank" rel="noreferrer noopener">{r.company}</a>
        ) : (
          <span>{r.company}</span>
        )}
      </div>
      <p class="text-sm text-muted/60 mt-1">{r.summary}</p>
    </div>
  ))}
</div>
