---
import BaseLayout from '../layouts/BaseLayout.astro';
import CommandPalette from '../components/CommandPalette.astro';
import cv from '../../cv.json';

type System = {
  name: string;
  purpose: string;
  capabilities: string[];
  scope: string;
  evidence: string;
  url: string;
};
---
<BaseLayout title={`${cv.name}`} description={cv.hero.primary} theme={cv.dataTheme}>
  <main class="max-w-[960px] mx-auto px-6 py-16 md:py-24">
    
    <!-- HERO -->
    <header class="mb-20">
      <h1 class="text-[1.625rem] md:text-[1.95rem] font-bold text-text tracking-tight leading-snug">
        {cv.hero.primary}
      </h1>
      <p class="mt-4 text-sm text-muted leading-relaxed max-w-md">
        {cv.hero.secondary}
      </p>
      <p class="mt-3 text-xs text-muted/60">
        {cv.hero.tertiary}
      </p>
    </header>

    <!-- SYSTEMS -->
    <section id="systems" class="mb-20">
      <h2 class="text-[11px] font-semibold tracking-[0.2em] uppercase text-muted mb-8">Systems</h2>
      
      <!-- Primary Systems -->
      <div class="space-y-10 mb-12">
        {cv.systems.primary.map((s: System, i: number) => (
          <article class={i === 0 ? 'border-l-[3px] border-text pl-5 pt-1' : 'border-l-2 border-text/60 pl-5'}>
            <h3 class={`text-base font-semibold tracking-tight ${i === 0 ? 'text-text' : 'text-text/90'}`}>{s.name}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{s.purpose}</p>
            <ul class="mt-4 space-y-1">
              {s.capabilities.map((c: string) => (
                <li class="text-sm text-muted/80 flex items-start gap-2">
                  <span class="text-text/20 select-none">—</span>
                  {c}
                </li>
              ))}
            </ul>
            <div class="mt-4 space-y-1 text-xs text-muted/60">
              <div><span class="text-muted/40">Scope:</span> {s.scope}</div>
              <div><span class="text-muted/40">Evidence:</span> {s.evidence}</div>
            </div>
            <a href={s.url} target="_blank" rel="noreferrer noopener" class="inline-block mt-4 text-xs text-primary hover:underline">GitHub →</a>
          </article>
        ))}
      </div>

      <!-- Foundational Systems -->
      <div class="border-t border-border pt-8">
        <div class="space-y-4">
          {cv.systems.foundational.map((s: System) => (
            <article>
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="text-sm font-medium text-text/80">{s.name}</h3>
                <a href={s.url} target="_blank" rel="noreferrer noopener" class="text-[10px] text-muted/50 hover:text-primary">GitHub →</a>
              </div>
              <p class="mt-1 text-sm text-muted/70">{s.purpose}</p>
              <div class="mt-1.5 text-xs text-muted/50">
                <span>Scope:</span> {s.scope}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section id="work" class="mb-16">
      <h2 class="text-[11px] font-semibold tracking-[0.2em] uppercase text-muted mb-6">Work</h2>
      <div class="space-y-6">
        {cv.work.map((w: {role: string; company: string; location?: string; time?: string; description: string}) => (
          <div>
            <div class="flex items-baseline justify-between gap-4">
              <div class="text-sm text-text">{w.role}</div>
              {w.time && <div class="text-[10px] text-muted/50 font-mono">{w.time}</div>}
            </div>
            <div class="text-sm text-muted/70">{w.company}{w.location && ` — ${w.location}`}</div>
            <p class="mt-2 text-sm text-muted/60 leading-relaxed">{w.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- EDUCATION -->
    <section id="education" class="mb-16">
      <h2 class="text-[11px] font-semibold tracking-[0.2em] uppercase text-muted mb-6">Education</h2>
      <div>
        <div class="text-sm text-text">{cv.education.school}</div>
        <div class="text-sm text-muted/70">{cv.education.program}</div>
        <div class="text-xs text-muted/50 mt-1">{cv.education.years}</div>
      </div>
    </section>

    <!-- LINKS -->
    <section id="links" class="mb-16">
      <h2 class="text-[11px] font-semibold tracking-[0.2em] uppercase text-muted mb-6">Links</h2>
      <div class="flex gap-6 text-sm">
        {cv.links.map((l: {label: string; url: string}) => (
          <a href={l.url} target={l.url.startsWith('http') ? '_blank' : undefined} rel="noreferrer noopener" class="text-muted/60 hover:text-primary transition-colors">{l.label}</a>
        ))}
      </div>
    </section>

    <footer class="border-t border-border pt-8">
      <div class="text-[10px] text-muted/40 font-mono">© {new Date().getFullYear()} {cv.name}</div>
    </footer>
  </main>

  <CommandPalette actions={[
    { id: 'go-systems', title: 'Go to Systems', hotkey: ['g','s'], handler: '#systems', section: 'Navigate' },
    { id: 'go-work', title: 'Go to Work', hotkey: ['g','w'], handler: '#work', section: 'Navigate' },
    { id: 'go-education', title: 'Go to Education', hotkey: ['g','e'], handler: '#education', section: 'Navigate' },
    { id: 'go-links', title: 'Go to Links', hotkey: ['g','l'], handler: '#links', section: 'Navigate' },
    ...cv.links.map((l: {label: string; url: string}, i: number) => ({ id: `link-${i}`, title: l.label, handler: l.url, section: 'Links' }))
  ]} />
</BaseLayout>
