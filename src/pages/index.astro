---
import BaseLayout from '../layouts/BaseLayout.astro';
import CommandPalette from '../components/CommandPalette.astro';
import cv from '../../cv.json';

type System = {
  name: string;
  purpose: string;
  capabilities: string[];
  scope: string;
  evidence: string;
  url: string;
};
---
<BaseLayout title={cv.name} description={cv.hero.primary} theme={cv.dataTheme}>
  <main class="max-w-[580px] mx-auto px-6 pt-36 pb-24 md:pt-48 md:pb-36">

    <!-- Hero -->
    <header class="mb-40 md:mb-52">
      <h1 class="text-4xl font-semibold text-text tracking-tight leading-[1.05]">
        {cv.hero.primary}
      </h1>
      <p class="mt-8 text-[0.9375rem] text-muted/50 leading-relaxed max-w-[400px]">
        {cv.hero.secondary}
      </p>
      <p class="mt-3 text-sm text-muted/30">
        {cv.hero.tertiary}
      </p>
    </header>

    <!-- Primary projects -->
    <section class="mb-40 md:mb-52 space-y-28">
      {cv.systems.primary.map((s: System, i: number) => (
        <article>
          <a href={s.url} target="_blank" rel="noreferrer noopener" class="group block">
            <h2 class="text-xl font-medium text-text tracking-tight group-hover:text-text/70 transition-colors duration-500">{s.name}</h2>
            <p class="mt-2 text-[0.9375rem] text-muted/60 leading-relaxed">{s.purpose}</p>
            <div class="mt-5 space-y-2">
              {s.capabilities.map((c: string) => (
                <p class="text-sm text-muted/35 leading-relaxed">{c}</p>
              ))}
            </div>
          </a>

          {/* Deadreckon — missile intercept */}
          {i === 0 && (
            <div id="guidance-scroll" class="relative h-[200vh] -mx-6 md:-mx-0 mt-16">
              <div class="sticky top-[20vh] h-[60vh] flex items-center justify-center">
                <svg
                  id="guidance-svg"
                  viewBox="0 0 400 240"
                  class="w-full max-w-[420px] h-auto"
                  fill="none"
                  aria-hidden="true"
                >
                  {/* Missile trail */}
                  <path id="missile-trail" d="" stroke="var(--text)" stroke-width="1" stroke-linecap="round" opacity="0.15" />
                  {/* Aircraft trail */}
                  <path id="aircraft-trail" d="" stroke="var(--text)" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.08" />
                  {/* Aircraft dot */}
                  <circle id="aircraft" r="3" fill="var(--text)" opacity="0" />
                  {/* Missile dot */}
                  <circle id="missile" r="3.5" fill="var(--text)" opacity="0" />
                  {/* Intercept flash */}
                  <circle id="intercept-flash" r="0" fill="var(--text)" opacity="0" />
                </svg>
              </div>
            </div>
          )}

          {/* Propagator — state propagation */}
          {i === 1 && (
            <div id="propagator-scroll" class="relative h-[180vh] -mx-6 md:-mx-0 mt-16">
              <div class="sticky top-[20vh] h-[60vh] flex items-center justify-center">
                <svg
                  id="propagator-svg"
                  viewBox="0 0 400 280"
                  class="w-full max-w-[420px] h-auto"
                  fill="none"
                  aria-hidden="true"
                >
                  {/* Ground plane */}
                  <line x1="0" y1="240" x2="400" y2="240" stroke="var(--text)" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.15" />
                  {/* Propagated trajectory */}
                  <path id="prop-trail" d="" stroke="var(--text)" stroke-width="1.5" stroke-linecap="round" />
                  {/* RK4 sample ticks along the path */}
                  <g id="prop-ticks"></g>
                  {/* Body dot */}
                  <circle id="prop-body" r="4" fill="var(--text)" opacity="0" />
                  {/* Velocity vector from body */}
                  <line id="prop-velocity" stroke="var(--text)" stroke-width="0.75" stroke-linecap="round" opacity="0" />
                </svg>
              </div>
            </div>
          )}
        </article>
      ))}
    </section>

    <!-- Secondary projects -->
    <section class="mb-40 md:mb-52 space-y-8">
      {cv.systems.foundational.map((s: System) => (
        <a href={s.url} target="_blank" rel="noreferrer noopener" class="group block">
          <span class="text-[0.9375rem] font-medium text-text/60 group-hover:text-text transition-colors duration-500">{s.name}</span>
          <span class="text-sm text-muted/30 ml-3">{s.purpose}</span>
        </a>
      ))}
    </section>

    <!-- Infrastructure -->
    <section class="mb-40 md:mb-52">
      <p class="text-sm text-muted/30 leading-relaxed">
        {cv.infrastructure.summary}
      </p>
    </section>

    <!-- Work -->
    <section class="mb-40 md:mb-52 space-y-10">
      {cv.work.map((w: { role: string; company: string; location?: string; time?: string; description: string }) => (
        <div>
          <div class="text-[0.9375rem] font-medium text-text">{w.role}</div>
          <div class="mt-1 text-sm text-muted/35">
            {w.company}{w.time && ` · ${w.time}`}
          </div>
          <p class="mt-2 text-sm text-muted/30 leading-relaxed">{w.description}</p>
        </div>
      ))}
    </section>

    <!-- Education -->
    <section class="mb-40 md:mb-52">
      <div class="text-[0.9375rem] font-medium text-text">{cv.education.school}</div>
      <div class="text-sm text-muted/35 mt-1">
        {cv.education.program} · {cv.education.years}
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="flex gap-8 text-sm text-muted/30">
        {cv.links.map((l: { label: string; url: string }) => (
          <a
            href={l.url}
            target={l.url.startsWith('http') ? '_blank' : undefined}
            rel="noreferrer noopener"
            class="hover:text-text/60 transition-colors duration-500"
          >{l.label}</a>
        ))}
      </div>
    </footer>
  </main>

  <script>
    // Fade-in observer
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('main > *').forEach((el) => {
      el.classList.add('fade-section');
      observer.observe(el);
    });

    // ---- Deadreckon: proportional navigation intercept with evasive aircraft ----
    function initGuidance() {
      const section = document.getElementById('guidance-scroll');
      const missileEl = document.getElementById('missile');
      const aircraftEl = document.getElementById('aircraft');
      const missileTrail = document.getElementById('missile-trail');
      const aircraftTrail = document.getElementById('aircraft-trail');
      const flash = document.getElementById('intercept-flash');
      if (!section || !missileEl || !aircraftEl || !missileTrail || !aircraftTrail || !flash) return;

      // Precompute the engagement at high resolution
      const N = 4.5; // navigation constant
      const dt = 0.01;
      const missileSpeed = 260; // high speed to allow extreme curves
      const aircraftSpeed = 130;
      const steps: { mx: number; my: number; ax: number; ay: number }[] = [];

      let mx = 40, my = 200, mAng = -Math.PI / 3;
      let ax = 320, ay = 50, aAng = Math.PI * 0.8;
      let lastLos: number | null = null;

      for (let t = 0; t < 3000; t++) {
        const time = t * dt;
        steps.push({ mx, my, ax, ay });

        // Evasive aircraft logic: S-curve (pulls one way, then breaks hard the other way)
        let turnRate = 0;
        if (time > 0.4 && time < 1.4) turnRate = -1.8; // bank right (upwards)
        else if (time >= 1.4 && time < 2.6) turnRate = 2.2; // break hard left (downwards)

        aAng += turnRate * dt;
        ax += aircraftSpeed * Math.cos(aAng) * dt;
        ay += aircraftSpeed * Math.sin(aAng) * dt;

        // Proportional navigation calculation
        const rx = ax - mx, ry = ay - my;
        const dist = Math.sqrt(rx * rx + ry * ry);
        if (dist < 4) break; // intercept achieved

        const losAngle = Math.atan2(ry, rx);
        if (lastLos !== null) {
          let dLos = losAngle - lastLos;
          // Normalize angle wrapping
          while (dLos > Math.PI) dLos -= 2 * Math.PI;
          while (dLos < -Math.PI) dLos += 2 * Math.PI;
          const losRate = dLos / dt;

          let cmdRate = N * losRate;
          cmdRate = Math.max(-6, Math.min(6, cmdRate)); // G-limit to create sweeping curves
          mAng += cmdRate * dt;
        }
        lastLos = losAngle;

        mx += missileSpeed * Math.cos(mAng) * dt;
        my += missileSpeed * Math.sin(mAng) * dt;

        if (mx < -50 || mx > 450 || my < -50 || my > 300) break; // offscreen fail/finish
      }

      const total = steps.length;
      let ticking = false;

      function update() {
        const rect = section!.getBoundingClientRect();
        const scrollable = rect.height - window.innerHeight;
        const progress = Math.max(0, Math.min(1, -rect.top / scrollable));

        const idx = Math.min(total - 1, Math.floor(progress * total));

        // Build continuous curves up to the current moment
        let mPath = '';
        let aPath = '';
        const step = 2; // step by 2 to keep path building cheap but smooth
        for (let i = 0; i <= idx; i += step) {
          const s = steps[i];
          const cmd = i === 0 ? 'M' : 'L';
          mPath += `${cmd}${s.mx.toFixed(1)} ${s.my.toFixed(1)}`;
          aPath += `${cmd}${s.ax.toFixed(1)} ${s.ay.toFixed(1)}`;
        }
        // Exactly connect the final point
        const cur = steps[idx];
        mPath += `L${cur.mx.toFixed(1)} ${cur.my.toFixed(1)}`;
        aPath += `L${cur.ax.toFixed(1)} ${cur.ay.toFixed(1)}`;

        missileTrail!.setAttribute('d', mPath);
        aircraftTrail!.setAttribute('d', aPath);

        missileEl!.setAttribute('cx', `${cur.mx}`);
        missileEl!.setAttribute('cy', `${cur.my}`);
        missileEl!.style.opacity = progress > 0.005 ? '1' : '0';

        aircraftEl!.setAttribute('cx', `${cur.ax}`);
        aircraftEl!.setAttribute('cy', `${cur.ay}`);
        aircraftEl!.style.opacity = progress > 0.005 ? '0.4' : '0';

        // Flash exactly at intercept point
        const isEnd = idx >= total - 5;
        if (isEnd && progress > 0.01) {
          flash!.setAttribute('cx', `${cur.mx}`);
          flash!.setAttribute('cy', `${cur.my}`);
          flash!.setAttribute('r', '8');
          flash!.style.opacity = '0.15';
        } else {
          flash!.style.opacity = '0';
        }

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });
    }

    // ---- Propagator: bouncing projectile under gravity and drag ----
    function initPropagator() {
      const section = document.getElementById('propagator-scroll');
      const bodyEl = document.getElementById('prop-body');
      const trailEl = document.getElementById('prop-trail');
      const ticksG = document.getElementById('prop-ticks');
      const velEl = document.getElementById('prop-velocity');
      if (!section || !bodyEl || !trailEl || !ticksG || !velEl) return;

      // Simulate a projectile with gravity, drag, and floor collision
      const g = 280;
      const dragK = 0.001;
      const restitution = 0.65; // bounce energy retention
      const friction = 0.85; 
      const dt = 0.015;
      const points: { x: number; y: number; vx: number; vy: number }[] = [];

      const radius = 4;
      const groundY = 240 - radius;
      let x = 20, y = 140, vx = 160, vy = -200;

      for (let t = 0; t < 1200; t++) {
        points.push({ x, y, vx, vy });
        
        const speed = Math.sqrt(vx * vx + vy * vy);
        const ax = -dragK * speed * vx;
        const ay = g - dragK * speed * vy;
        
        vx += ax * dt;
        vy += ay * dt;
        x += vx * dt;
        y += vy * dt;
        
        // Ground bounce condition
        if (y >= groundY) {
          y = groundY;
          vy = -vy * restitution;
          vx = vx * friction;
          if (Math.abs(vy) < 15) vy = 0; // come to rest cleanly
        }
        
        if (x > 390 && vx > 0) break;
        if (vx < 1 && Math.abs(vy) === 0 && y === groundY) break;
      }

      const total = points.length;

      // RK4/Simulation sample ticks at intervals
      const tickPositions: number[] = [];
      for (let i = 0; i < total; i += 12) {
        tickPositions.push(i);
      }

      let ticking = false;

      function update() {
        const rect = section!.getBoundingClientRect();
        const scrollable = rect.height - window.innerHeight;
        const progress = Math.max(0, Math.min(1, -rect.top / scrollable));

        const idx = Math.min(total - 1, Math.floor(progress * total));
        const cur = points[idx];

        let d = '';
        const step = 2;
        for (let i = 0; i <= idx; i += step) {
          d += `${i === 0 ? 'M' : 'L'}${points[i].x.toFixed(1)} ${points[i].y.toFixed(1)}`;
        }
        d += `L${cur.x.toFixed(1)} ${cur.y.toFixed(1)}`;

        trailEl!.setAttribute('d', d);

        bodyEl!.setAttribute('cx', `${cur.x}`);
        bodyEl!.setAttribute('cy', `${cur.y}`);
        bodyEl!.style.opacity = progress > 0.005 ? '1' : '0';

        // Velocity vector shows inertia & sharp changes on bounce
        const vScale = 0.12;
        velEl!.setAttribute('x1', `${cur.x}`);
        velEl!.setAttribute('y1', `${cur.y}`);
        velEl!.setAttribute('x2', `${cur.x + cur.vx * vScale}`);
        velEl!.setAttribute('y2', `${cur.y + cur.vy * vScale}`);
        velEl!.style.opacity = progress > 0.005 && progress < 0.99 ? '0.3' : '0';

        // Render integration ticks up to current propagation point
        let ticksHTML = '';
        for (const ti of tickPositions) {
          if (ti > idx) break;
          const p = points[ti];
          ticksHTML += `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="1.5" fill="var(--text)" opacity="0.1"/>`;
        }
        ticksG!.innerHTML = ticksHTML;

        ticking = false;
      }

      window.addEventListener('scroll', () => {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
      }, { passive: true });
    }

    initGuidance();
    initPropagator();
  </script>

  <CommandPalette actions={[
    ...cv.links.map((l: { label: string; url: string }, i: number) => ({
      id: `link-${i}`,
      title: l.label,
      handler: l.url,
      section: 'Links',
    })),
  ]} />
</BaseLayout>
